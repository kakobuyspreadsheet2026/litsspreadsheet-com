{
  "name": "litbuyspreadsheet-com",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev --port 4789 --host",
    "prebuild": "node scripts/fetch-featured.mjs",
    "sync:litrepstar-home": "REFRESH_LITREPSTAR=1 node scripts/fetch-litrepstar-home.mjs",
    "sync:litrepstar-prices": "node scripts/backfill-litrepstar-prices.mjs",
    "sync:catalog-images": "node scripts/migrate-catalog-images.mjs",
