# Copy to .env to override the default LitBuy outbound catalogue CTA URL
# Default if unset: https://litrepstar.com/en
PUBLIC_LITBUY_SPREADSHEET_URL=

# Homepage trending picks (`litrepstarHomePicks.json` + `public/images/litrepstar/picks/`)
# are pinned in git — deploy does NOT re-fetch. Manual refresh:
# npm run sync:litrepstar-home

# Prebuild (`npm run build`) uses committed catalog JSON by default:
#   - featured-products.json  → homepage Editor's Pick
#   - category-products.json  → category grids + spreadsheet PDP pool
# Opt in to live Litrepstar catalog refresh:
# REFRESH_CATALOG=1
# Or refresh individually:
# REFRESH_FEATURED=1
# REFRESH_CATEGORIES=1

# TOP promo strip → `/join/discord` redirect (optional; default in src/consts.ts).
# PUBLIC_LITBUY_DISCORD_URL=https://discord.com/invite/litbuyspreadsheet

# Floating right dock (Video / Discord / Reddit / WhatsApp). Optional overrides — see defaults in src/consts.ts.
# PUBLIC_FLOAT_VIDEO_URL=/videos/intro.mp4
# PUBLIC_FLOAT_DISCORD_URL=https://discord.com/invite/litbuyspreadsheet
# PUBLIC_FLOAT_REDDIT_URL=https://www.reddit.com/r/litbuyspreadsheet/
# PUBLIC_FLOAT_WHATSAPP_URL=https://wa.me/your-whatsapp-number
