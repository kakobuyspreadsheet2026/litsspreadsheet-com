---
import { absoluteCanonicalUrl } from '../lib/canonicalPath';

import Layout from '../layouts/Layout.astro';
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';
import BlogEndCta from './BlogEndCta.astro';
import BlogCatalogCrossLinks from './BlogCatalogCrossLinks.astro';
import { getBlogCatalogCategories } from '../lib/blogCatalogCrossLinkMap';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { defaultOgImagePath, siteStructuredDataIds, siteOrigin } from '../consts';
import { HTML_LANG_BY_ROUTE } from '../i18n/config';
import { breadcrumbListLd } from '../lib/breadcrumbSchema';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  headline: string;
  publishedISO: string;
  modifiedISO?: string;
  displayDate: string;
  ogImage?: string;
  structuredKeywords?: readonly string[];
  articleAuthor?: string;
}

const {
  title,
  description,
  canonicalPath,
  headline,
  publishedISO,
  modifiedISO,
  displayDate,
  ogImage,
  structuredKeywords,
  articleAuthor,
} = Astro.props;

const modifiedIsoEffective = modifiedISO ?? publishedISO;

const locale = 'en';
const blogIndexHref = getRelativeLocaleUrl(locale, 'blog');
const homeHref = getRelativeLocaleUrl(locale, '');

const origin = Astro.site?.origin ?? siteOrigin;
const { organizationId, websiteId } = siteStructuredDataIds(origin);
const pageUrl = absoluteCanonicalUrl(canonicalPath, Astro.site);
const shareImageUrl =
  ogImage && /^https?:\/\//i.test(ogImage)
    ? ogImage
    : ogImage
      ? new URL(ogImage, Astro.site).href
      : new URL(defaultOgImagePath, Astro.site).href;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${pageUrl}#article`,
  url: pageUrl,
  headline,
  image: [shareImageUrl],
  datePublished: publishedISO,
  dateModified: modifiedIsoEffective,
  author: articleAuthor
    ? { '@type': 'Person', name: articleAuthor }
    : { '@type': 'Organization', name: 'litsspreadsheet.com editorial' },
  publisher: { '@id': organizationId },
  description,
  ...(structuredKeywords?.length ? { keywords: [...structuredKeywords] } : {}),
  inLanguage: HTML_LANG_BY_ROUTE.en,
  isPartOf: { '@id': websiteId },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
  },
};

const homeAbs = new URL(homeHref, Astro.site).href;
const blogAbs = new URL(blogIndexHref, Astro.site).href;
const breadcrumbLd = breadcrumbListLd([
  { name: 'Home', url: homeAbs },
  { name: 'Blog', url: blogAbs },
  { name: headline, url: pageUrl },
]);

const catalogCategories = getBlogCatalogCategories(canonicalPath);
---

<Layout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  locale={locale}
  hreflangLocales={['en']}
  hreflangMirrorsCanonical
  ogImage={ogImage}
  ogType="article"
  articlePublishedTime={publishedISO}
  articleModifiedTime={modifiedIsoEffective}
  jsonLd={[articleLd, breadcrumbLd]}
>
  <SiteHeader locale={locale} />

  <main>
    <section class="band-alt">
      <div class="wrap">
        <div class="page-mast">
          <nav class="blog-bc-nav" aria-label="Breadcrumb">
            <ol class="blog-bc-list">
              <li class="blog-bc-item">
                <a href={homeHref}>Home</a>
              </li>
              <li class="blog-bc-item">
                <a href={blogIndexHref}>Blog</a>
              </li>
              <li class="blog-bc-item blog-bc-current" aria-current="page">
                <span class="blog-bc-current-text">{headline}</span>
              </li>
            </ol>
          </nav>

          <article class="blog-piece" lang="en">
            <header class="blog-piece-head">
              <h1 class="simple-page-title">{headline}</h1>
              <p class="blog-piece-meta">
                <time datetime={publishedISO}>{displayDate}</time>
                <span>
                  {
                    articleAuthor
                      ? ` · By ${articleAuthor} · litsspreadsheet.com`
                      : ` · Editorial · litsspreadsheet.com`
                  }
                </span>
              </p>
              <div class="blog-lede-wrap">
                <slot name="lede" />
              </div>
            </header>

            <div class="blog-body prose-block">
              <slot />
              <BlogCatalogCrossLinks
                canonicalPath={canonicalPath}
                categories={catalogCategories}
              />
              <BlogEndCta locale={locale} canonicalPath={canonicalPath} />
              <p class="blog-disclaimer">
                <strong>Disclaimer:</strong> litsspreadsheet.com publishes independent editorial notes for LitBuy Spreadsheet shoppers—browse bridges,
                explainers, and mirrored notices—not checkout, warehousing, or dispute outcomes on litbuy.com. Features and policies change; rely on your
                signed-in LitBuy console for binding quotes and QC tooling.{' '}
                <a href="/about/">About &amp; editorial independence</a>.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter locale={locale} />
</Layout>

<style>
  .blog-bc-nav {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    color: var(--muted);
  }
  .blog-bc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: baseline;
  }
  .blog-bc-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    max-width: 100%;
  }
  .blog-bc-item:not(.blog-bc-current)::after {
    content: '/';
    color: var(--border);
    margin-left: 0.35rem;
    pointer-events: none;
    flex-shrink: 0;
  }
  .blog-bc-item a {
    font-weight: 600;
    color: var(--accent-dark, #0f766e);
    text-decoration: none;
  }
  .blog-bc-item a:hover {
    text-decoration: underline;
  }
  .blog-bc-current-text {
    display: inline-block;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
    word-break: break-word;
  }
  .blog-piece-head {
    margin-bottom: 1.25rem;
    max-width: 48rem;
  }
  .blog-piece-meta {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    color: var(--muted);
  }
  .blog-lede-wrap :global(.blog-lede) {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--text);
    max-width: 48rem;
  }
  .blog-piece {
    max-width: 52rem;
  }
  .prose-block {
    font-size: 0.975rem;
    line-height: 1.7;
    color: var(--muted);
  }
  .prose-block :where(h2) {
    margin: 1.75rem 0 0.65rem;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
  }
  .prose-block :where(h2:first-child) {
    margin-top: 0;
  }
  .prose-block :where(h3) {
    margin: 1.25rem 0 0.45rem;
    font-size: 1.02rem;
    font-weight: 700;
    color: var(--text);
  }
  .prose-block :where(p) {
    margin: 0 0 0.85rem;
  }
  .prose-block :where(ul, ol) {
    margin: 0 0 0.85rem;
    padding-left: 1.35rem;
  }
  .prose-block :where(li) {
    margin-bottom: 0.4rem;
  }
  .prose-block :where(strong) {
    color: var(--text);
  }
  .prose-block :where(a) {
    font-weight: 600;
    color: var(--accent-dark, #0f766e);
  }
  .prose-block .blog-table-wrap {
    overflow-x: auto;
    margin: 0 0 1rem;
    -webkit-overflow-scrolling: touch;
  }
  .prose-block :where(table) {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .prose-block :where(caption) {
    caption-side: bottom;
    padding: 0.5rem 0 0;
    font-size: 0.82rem;
    color: var(--muted);
    text-align: left;
  }
  .prose-block :where(th, td) {
    border: 1px solid var(--border);
    padding: 0.45rem 0.55rem;
    vertical-align: top;
    text-align: left;
  }
  .prose-block :where(th) {
    font-weight: 700;
    color: var(--text);
    background: color-mix(in srgb, var(--border) 35%, transparent);
  }

  .blog-disclaimer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.9rem;
  }
</style>
