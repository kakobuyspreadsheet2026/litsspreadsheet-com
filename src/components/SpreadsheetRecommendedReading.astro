---
import blogPosts from '../data/blogPosts.json';
import { BLOG_EDITORIAL_PILLARS } from '../lib/blogTopicClusters';

interface Props {
  title?: string;
  intro?: string;
}

const {
  title = 'Recommended editorial guides',
  intro = 'English blog notes that pair with this spreadsheet guide—warehouse QC, customs, and paste workflows.',
} = Astro.props;

const postBySlug = new Map(
  (blogPosts as { slug: string; title: string }[]).map((p) => [p.slug, p]),
);

const pillars = BLOG_EDITORIAL_PILLARS.map((p) => ({
  ...p,
  title: postBySlug.get(p.slug)?.title ?? p.slug,
})).filter((p) => postBySlug.has(p.slug));
---

{
  pillars.length > 0 ? (
    <section class="ssp-reading" id="ssp-recommended-reading" aria-labelledby="ssp-reading-heading">
      <h2 id="ssp-reading-heading" class="ssp-block-title">{title}</h2>
      <p class="section-intro ssp-prose-tight">{intro}</p>
      <ul class="ssp-reading__list">
        {pillars.map((item) => (
          <li class="ssp-reading__item">
            <a class="ssp-reading__link" href={`/blog/${item.slug}/`}>
              {item.title}
            </a>
            <p class="ssp-reading__blurb">{item.blurb}</p>
          </li>
        ))}
      </ul>
      <p class="ssp-reading__more">
        <a href="/blog/topics/eu-customs/">EU customs topic hub</a>
        {' · '}
        <a href="/blog/">All blog guides</a>
      </p>
    </section>
  ) : null
}

<style>
  .ssp-reading {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
  }

  .ssp-reading__list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 52rem;
    display: grid;
    gap: 0.75rem;
  }

  .ssp-reading__item {
    margin: 0;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--surface);
    text-align: left;
  }

  .ssp-reading__link {
    font-weight: 700;
    color: var(--oob-pink, #ff1e6f);
    text-decoration: none;
    line-height: 1.35;
  }

  .ssp-reading__link:hover {
    text-decoration: underline;
  }

  .ssp-reading__blurb {
    margin: 0.3rem 0 0;
    font-size: 0.86rem;
    line-height: 1.5;
    color: var(--muted);
  }

  .ssp-reading__more {
    margin: 1rem auto 0;
    max-width: 52rem;
    font-size: 0.86rem;
    font-weight: 600;
    text-align: center;
  }

  .ssp-reading__more a {
    color: var(--oob-pink, #ff1e6f);
  }
</style>
