        <text x="500" y="102" text-anchor="middle" font-size="11" fill="#64748b">Domestic only</text>
        <rect x="630" y="50" width="140" height="70" rx="8" fill="#fff" stroke="#0f766e" />
        <text x="700" y="82" text-anchor="middle" font-size="13" font-weight="700" fill="#0f172a">Approve ship</text>
        <text x="700" y="102" text-anchor="middle" font-size="11" fill="#64748b">International</text>
      </svg>
    </figure>
  )
}

{
  slug === 'spreadsheet-volumetric-chargeable-weight-basics' && (
    <figure class="blog-diagram" aria-labelledby={captionId}>
      <figcaption id={captionId} class="blog-diagram__caption">
        {diagramAlt}
      </figcaption>
      <svg class="blog-diagram__svg" viewBox="0 0 800 200" role="img" aria-hidden="true">
        <rect width="800" height="200" rx="12" fill="#f8fafc" stroke="#e2e8f0" />
        <text x="400" y="45" text-anchor="middle" font-size="14" font-weight="700" fill="#0f172a">
          Volumetric kg = L × W × H ÷ divisor (carrier-specific)
        </text>
