      <svg class="blog-diagram__svg" viewBox="0 0 800 160" role="img" aria-hidden="true">
        <rect width="800" height="160" rx="12" fill="#f8fafc" stroke="#e2e8f0" />
        <rect x="40" y="50" width="108" height="70" rx="6" fill="#fff" stroke="#cbd5e1" />
        <text x="94" y="92" text-anchor="middle" font-size="11" font-weight="700" fill="#0f172a">Item CNY</text>
        <rect x="162" y="50" width="108" height="70" rx="6" fill="#fff" stroke="#cbd5e1" />
