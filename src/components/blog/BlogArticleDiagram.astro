---
import { getBlogDiagramAlt } from '../../lib/blogImages';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const diagramAlt = getBlogDiagramAlt(slug);

if (!diagramAlt) return null;

const captionId = `diagram-${slug.replace(/[^a-z0-9]+/gi, '-').replace(/^-|-$/g, '')}`;
---

{
  slug === 'eu-customs-reform-july-2026-litbuy-spreadsheet' && (
    <figure class="blog-diagram" aria-labelledby={captionId}>
      <figcaption id={captionId} class="blog-diagram__caption">
        {diagramAlt}
      </figcaption>
      <svg class="blog-diagram__svg" viewBox="0 0 800 220" role="img" aria-hidden="true">
        <rect width="800" height="220" rx="12" fill="#f8fafc" stroke="#e2e8f0" />
        <line x1="80" y1="110" x2="720" y2="110" stroke="#0f766e" stroke-width="4" />
        <circle cx="120" cy="110" r="10" fill="#0f766e" />
        <text x="120" y="78" text-anchor="middle" font-size="13" font-weight="700" fill="#0f172a">30 Jun 2026</text>
        <text x="120" y="148" text-anchor="middle" font-size="12" fill="#475569">€150 duty relief ends</text>
        <circle cx="320" cy="110" r="10" fill="#ff1e6f" />
        <text x="320" y="78" text-anchor="middle" font-size="13" font-weight="700" fill="#0f172a">1 Jul 2026</text>
        <text x="320" y="148" text-anchor="middle" font-size="12" fill="#475569">€3/item bridge duty</text>
        <circle cx="520" cy="110" r="10" fill="#0f766e" />
        <text x="520" y="78" text-anchor="middle" font-size="13" font-weight="700" fill="#0f172a">Nov 2026</text>
        <text x="520" y="148" text-anchor="middle" font-size="12" fill="#475569">PIDs mandatory</text>
        <circle cx="680" cy="110" r="10" fill="#0f766e" />
        <text x="680" y="78" text-anchor="middle" font-size="13" font-weight="700" fill="#0f172a">Jul 2028</text>
        <text x="680" y="148" text-anchor="middle" font-size="12" fill="#475569">Customs Data Hub</text>
      </svg>
    </figure>
  )
}

{
  slug === 'litbuy-618-shopping-festival-2026-spreadsheet' && (
    <figure class="blog-diagram" aria-labelledby={captionId}>
      <figcaption id={captionId} class="blog-diagram__caption">
        {diagramAlt}
      </figcaption>
      <svg class="blog-diagram__svg" viewBox="0 0 800 200" role="img" aria-hidden="true">
        <rect width="800" height="200" rx="12" fill="#f8fafc" stroke="#e2e8f0" />
        <rect x="35" y="70" width="110" height="60" rx="8" fill="#0f766e" fill-opacity="0.12" stroke="#0f766e" />
        <text x="90" y="105" text-anchor="middle" font-size="12" font-weight="700" fill="#0f172a">Intake thresholds</text>
        <rect x="195" y="70" width="110" height="60" rx="8" fill="#0f766e" fill-opacity="0.12" stroke="#0f766e" />
        <text x="250" y="105" text-anchor="middle" font-size="12" font-weight="700" fill="#0f172a">Wave A ship-first</text>
        <rect x="355" y="70" width="110" height="60" rx="8" fill="#ff1e6f" fill-opacity="0.12" stroke="#ff1e6f" />
        <text x="410" y="105" text-anchor="middle" font-size="12" font-weight="700" fill="#0f172a">QC pass/fail</text>
        <rect x="515" y="70" width="110" height="60" rx="8" fill="#0f766e" fill-opacity="0.12" stroke="#0f766e" />
        <text x="570" y="105" text-anchor="middle" font-size="12" font-weight="700" fill="#0f172a">Wave B consolidate</text>
        <rect x="675" y="70" width="110" height="60" rx="8" fill="#0f766e" fill-opacity="0.12" stroke="#0f766e" />
        <text x="730" y="105" text-anchor="middle" font-size="12" font-weight="700" fill="#0f172a">Freight model</text>
      </svg>
    </figure>
  )
}

{
  slug === 'litbuy-spreadsheet-qc' && (
    <figure class="blog-diagram" aria-labelledby={captionId}>
      <figcaption id={captionId} class="blog-diagram__caption">
        {diagramAlt}
      </figcaption>
      <svg class="blog-diagram__svg" viewBox="0 0 800 180" role="img" aria-hidden="true">
        <rect width="800" height="180" rx="12" fill="#f8fafc" stroke="#e2e8f0" />
        <rect x="30" y="50" width="140" height="70" rx="8" fill="#fff" stroke="#0f766e" />
        <text x="100" y="82" text-anchor="middle" font-size="13" font-weight="700" fill="#0f172a">Photos in</text>
        <text x="100" y="102" text-anchor="middle" font-size="11" fill="#64748b">Review angles</text>
