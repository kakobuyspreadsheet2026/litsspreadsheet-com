        <text x="338" y="92" text-anchor="middle" font-size="11" font-weight="700" fill="#0f172a">FX note</text>
        <rect x="406" y="50" width="108" height="70" rx="6" fill="#fff" stroke="#cbd5e1" />
        <text x="460" y="92" text-anchor="middle" font-size="11" font-weight="700" fill="#0f172a">Declared EUR</text>
        <rect x="528" y="50" width="108" height="70" rx="6" fill="#fff" stroke="#cbd5e1" />
        <text x="582" y="92" text-anchor="middle" font-size="11" font-weight="700" fill="#0f172a">Duty line</text>
        <rect x="650" y="50" width="108" height="70" rx="6" fill="#fff" stroke="#cbd5e1" />
        <text x="704" y="92" text-anchor="middle" font-size="11" font-weight="700" fill="#0f172a">Freight</text>
      </svg>
