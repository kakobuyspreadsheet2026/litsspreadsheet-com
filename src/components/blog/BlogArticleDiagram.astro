  )
}

<style>
  .blog-diagram {
    margin: 1.5rem 0 1.75rem;
    max-width: 48rem;
  }

  .blog-diagram__caption {
    margin: 0 0 0.5rem;
    font-size: 0.84rem;
    font-weight: 700;
    color: var(--muted);
    text-align: left;
  }

  .blog-diagram__svg {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.55rem;
  }
</style>
