---
import { getRelatedBlogPosts, getTopicLabel } from '../lib/relatedBlogPosts';
import {
  getBlogTopicHubPath,
  getTopicsForBlogSlug,
} from '../lib/blogTopicClusters';

interface Props {
  slug: string;
  limit?: number;
}

const { slug, limit = 3 } = Astro.props;

const related = getRelatedBlogPosts(slug, limit);
const topics = getTopicsForBlogSlug(slug);

if (related.length === 0) return null;
---

<aside class="related-blog" aria-labelledby="related-blog-heading">
  <h2 id="related-blog-heading" class="related-blog__title">Related guides</h2>
  <ul class="related-blog__list">
    {
      related.map((post) => (
        <li class="related-blog__item">
          <a class="related-blog__link" href={`/blog/${post.slug}/`}>
            {post.title}
          </a>
          <p class="related-blog__desc">{post.description}</p>
        </li>
      ))
    }
  </ul>
  {
    topics.length > 0 ? (
      <p class="related-blog__topics">
        More in{' '}
        {topics.map((topicId, i) => (
          <>
            {i > 0 ? ', ' : ''}
            <a href={getBlogTopicHubPath(topicId)}>{getTopicLabel(topicId)}</a>
          </>
        ))}
      </p>
    ) : null
  }
</aside>

<style>
  .related-blog {
    margin: 2rem 0 0;
    padding: 1.15rem 1.2rem 1.2rem;
    border-radius: 0.65rem;
    border: 1px solid var(--border);
    background: var(--surface, #fff);
  }

  .related-blog__title {
    margin: 0 0 0.75rem;
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--text);
  }

  .related-blog__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .related-blog__link {
    font-weight: 700;
    color: var(--accent-dark, #0f766e);
    text-decoration: none;
    line-height: 1.35;
  }

  .related-blog__link:hover {
    text-decoration: underline;
  }

  .related-blog__desc {
    margin: 0.25rem 0 0;
    font-size: 0.86rem;
    line-height: 1.5;
    color: var(--muted);
  }

  .related-blog__topics {
    margin: 0.85rem 0 0;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    font-size: 0.84rem;
    color: var(--muted);
  }

  .related-blog__topics a {
    font-weight: 700;
    color: var(--accent-dark, #0f766e);
  }
</style>
