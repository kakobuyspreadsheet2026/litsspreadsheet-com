---
import { absoluteCanonicalUrl } from '../../lib/canonicalPath';

import Layout from '../../layouts/Layout.astro';
import LocaleHomeStub from '../../components/LocaleHomeStub.astro';
import { frHome } from '../../i18n/stubs/fr';
import { litbuyspreadsheetHomeHeroBannerUrl, litbuyspreadsheetHomeHeroMobileBannerUrl, siteStructuredDataIds, siteOrigin } from '../../consts';
import { getHotProductsLd } from '../../lib/hotProductsLd';
import { homeFaqPageLd } from '../../lib/homeFaqLd';

export const prerender = true;

const locale = 'fr';
const canonicalPath = '/fr/';
const origin = Astro.site?.origin ?? siteOrigin;
const { websiteId } = siteStructuredDataIds(origin);
const pageUrl = absoluteCanonicalUrl(canonicalPath, Astro.site);

const hotProductsLd = getHotProductsLd(origin, pageUrl);
const faqLd = homeFaqPageLd(pageUrl, frHome.sections);

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  name: frHome.webPageName,
  url: pageUrl,
  description: frHome.description,
  inLanguage: 'fr',
  isPartOf: { '@id': websiteId },
  keywords: frHome.webPageKeywords,
  mainEntity: { '@id': hotProductsLd['@id'] },
  hasPart: [{ '@id': faqLd['@id'] }],
};
---

<Layout
  locale={locale}
  title={frHome.title}
  description={frHome.description}
  canonicalPath={canonicalPath}
  i18nRouteSegment=""
  jsonLd={[webPageLd, hotProductsLd, faqLd]}
  showDiscordTopBanner={false}
  lcpPreloadImages={[litbuyspreadsheetHomeHeroBannerUrl]}
  mobileLcpPreloadImages={[litbuyspreadsheetHomeHeroMobileBannerUrl]}
>
  <LocaleHomeStub content={frHome} />
</Layout>
