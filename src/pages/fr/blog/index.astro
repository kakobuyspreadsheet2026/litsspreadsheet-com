---
import Layout from '../../../layouts/Layout.astro';
import BlogPageBody from '../../../components/pages/BlogPageBody.astro';
import { buildBlogPageProps } from '../../../lib/buildBlogPageProps';

export const prerender = true;

const props = buildBlogPageProps('fr', Astro.site);
---

<Layout
  title={props.layoutTitle}
  description={props.copy.description}
  canonicalPath={props.canonicalPath}
  locale={props.locale}
  i18nRouteSegment="blog"
  jsonLd={props.jsonLd}
  prevUrl={props.prevUrl}
  nextUrl={props.nextUrl}
>
  <BlogPageBody
    locale={props.locale}
    copy={props.copy}
    homeHref={props.homeHref}
    posts={props.listingPosts}
    listingPage={props.currentPage}
    totalListingPages={props.totalPages}
    breadcrumbUi={[
      { label: props.copy.breadcrumbHomeLabel, href: props.homeHref },
      { label: props.copy.h1 },
    ]}
  />
</Layout>
