---
import DiscordTopBanner from '../components/DiscordTopBanner.astro';
import FloatingDock from '../components/FloatingDock.astro';
import { i18n } from 'astro:config/client';
import { getAbsoluteLocaleUrlList, toCodes } from 'astro:i18n';
import {
  HREFLANG_BY_ROUTE,
  HTML_LANG_BY_ROUTE,
  OG_LOCALE_BY_ROUTE,
  ROUTE_LOCALES,
  normalizeRouteLocale,
  type RouteLocale,
} from '../i18n/config';
import {
  defaultCommunityRedditUrl,
  defaultLitbuyspreadsheetDiscordUrl,
  defaultOgImageHeight,
  defaultOgImagePath,
  defaultOgImageWidth,
  litbuyCheckoutOrigin,
  litrepstarCatalogRoot,
  siteName,
  siteOrigin as configuredSiteOrigin,
  siteDomain,
  siteStructuredDataIds,
  structuredDataLogoHeight,
  structuredDataLogoPath,
  structuredDataLogoWidth,
  interLatinFontUrl,
} from '../consts';
import { canonicalPathWithTrailingSlash } from '../lib/canonicalPath';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  locale?: string;
  i18nRouteSegment?:
    | ''
    | 'about'
    | 'how-to-buy'
    | 'news'
    | 'blog'
    | 'spreadsheet';
  /**
   * Locales that actually have a page for this URL (SEO: do not emit hreflang to 404s).
   * Default: all configured locales.
   */
  hreflangLocales?: RouteLocale[];
  /**
   * When true, every emitted `hreflang` alternate uses this page’s canonical URL (e.g. EN-only
   * blog posts where segment-based alternates would wrongly target `/blog/` hubs).
   */
  hreflangMirrorsCanonical?: boolean;
  /** Public path (e.g. `/foo.png`) or absolute URL; defaults to site-wide share image. */
  ogImage?: string;
  /** Open Graph type; use `article` for blog posts (adds `article:*` meta when timestamps provided). */
  ogType?: 'website' | 'article';
  /** ISO 8601 — emitted as `article:published_time` when `ogType` is `article`. */
  articlePublishedTime?: string;
  /** ISO 8601 — emitted as `article:modified_time` when `ogType` is `article`. */
  articleModifiedTime?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** When false, the Layout thin LitBuy promo strip above `<slot />` is omitted (homepage renders `LitBuyHomeHero`, which already includes the same strip). */
  showDiscordTopBanner?: boolean;
  /** Absolute image URLs for `<link rel="preload" as="image">` (e.g. homepage hero background). */
  lcpPreloadImages?: readonly string[];
  /** Mobile-only LCP image preloads (`media="(max-width: 640px)"`). */
  mobileLcpPreloadImages?: readonly string[];
  /** Optional pagination previous link URL (absolute or relative-to-root) */
  prevUrl?: string;
  /** Optional pagination next link URL (absolute or relative-to-root) */
  nextUrl?: string;
  /** When true, emits <meta name="robots" content="noindex, follow">. */
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath = '/',
  locale: localeProp,
  i18nRouteSegment: segmentProp,
  hreflangLocales: hreflangLocalesProp,
  hreflangMirrorsCanonical = false,
  ogImage,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  jsonLd,
  showDiscordTopBanner = true,
  lcpPreloadImages,
  mobileLcpPreloadImages,
  prevUrl,
  nextUrl,
  noindex = false,
} = Astro.props;

const canonicalPathNormalized = canonicalPathWithTrailingSlash(canonicalPath);
const canonical = new URL(canonicalPathNormalized, Astro.site).href;
const locale = normalizeRouteLocale(
  localeProp ?? (Astro.currentLocale as RouteLocale | undefined),
);
const htmlLang = HTML_LANG_BY_ROUTE[locale];

function inferSegmentFromCanonical(pathOnly: string):
  | ''
  | 'about'
  | 'how-to-buy'
  | 'news'
  | 'blog'
  | 'spreadsheet' {
  let segs = pathOnly.replace(/\/$/, '').split('/').filter(Boolean);
  if (segs[0] && (ROUTE_LOCALES as readonly string[]).includes(segs[0])) {
    segs = segs.slice(1);
  }
  const joined = segs.join('/');
  if (
    joined === 'about' ||
    joined === 'how-to-buy' ||
    joined === 'news' ||
    joined === 'blog' ||
    joined === 'spreadsheet'
  )
    return joined as const;
  /** Deep routes like `/blog/post-slug` share the section’s localized hub for hreflang targets. */
  const primary = segs[0];
  if (
    primary === 'about' ||
    primary === 'how-to-buy' ||
    primary === 'news' ||
    primary === 'blog' ||
    primary === 'spreadsheet'
  )
    return primary;
  return '';
}

/** Path passed to `getAbsoluteLocaleUrlList` for hreflang alternates (may include slug, e.g. `category/shoes`). */
function inferHreflangListPath(pathOnly: string): string | undefined {
  let segs = pathOnly.replace(/\/$/, '').split('/').filter(Boolean);
  if (segs[0] && (ROUTE_LOCALES as readonly string[]).includes(segs[0])) {
    segs = segs.slice(1);
  }
  if (segs[0] === 'category' && segs[1]) {
    return `category/${segs[1]}`;
  }
  const segment = inferSegmentFromCanonical(pathOnly);
  return segment === '' ? undefined : segment;
}

const canonicalPathname = new URL(canonical).pathname;

const hreflangListPath =
  segmentProp !== undefined
    ? segmentProp === ''
      ? undefined
      : segmentProp
    : inferHreflangListPath(canonicalPathname);

const astroLocaleCodes = toCodes(i18n.locales);
const hreflangUrls = getAbsoluteLocaleUrlList(hreflangListPath);

const ogImageAbs =
  ogImage && /^https?:\/\//i.test(ogImage)
    ? ogImage
    : new URL(ogImage ?? defaultOgImagePath, Astro.site).href;
const defaultOgImageAbs = new URL(defaultOgImagePath, Astro.site).href;
const ogImageUsesDefaultDims = ogImageAbs === defaultOgImageAbs;
const siteOrigin = Astro.site?.origin ?? configuredSiteOrigin;
const { organizationId, websiteId } = siteStructuredDataIds(siteOrigin);
const logoUrl = new URL(structuredDataLogoPath, Astro.site).href;

const organizationLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': organizationId,
  name: siteName,
  url: siteOrigin,
  sameAs: [defaultLitbuyspreadsheetDiscordUrl, defaultCommunityRedditUrl],
  logo: {
    '@type': 'ImageObject',
    url: logoUrl,
    width: structuredDataLogoWidth,
    height: structuredDataLogoHeight,
  },
};

const websiteLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': websiteId,
  url: `${siteOrigin}/`,
  name: siteName,
  publisher: { '@id': organizationId },
  inLanguage: [...ROUTE_LOCALES],
};

const pageLd = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
const ld = [organizationLd, websiteLd, ...pageLd];

const hreflangClusters = astroLocaleCodes.map((code, i) => ({
  locale: normalizeRouteLocale(code.startsWith('pt') ? 'pt' : code),
  hreflang: HREFLANG_BY_ROUTE[normalizeRouteLocale(code.startsWith('pt') ? 'pt' : code)],
  href: hreflangMirrorsCanonical ? canonical : hreflangUrls[i],
}));

const allowedHreflangs = hreflangLocalesProp
  ? new Set(hreflangLocalesProp)
  : new Set<RouteLocale>([...ROUTE_LOCALES]);

const filteredHreflang = hreflangClusters.filter((c) => allowedHreflangs.has(c.locale));

const localeIndexOfEn = astroLocaleCodes.findIndex((c) => c === 'en' || String(c).startsWith('en'));
const xDefaultHref = hreflangMirrorsCanonical
  ? canonical
  : allowedHreflangs.has('en') && localeIndexOfEn >= 0
    ? hreflangUrls[localeIndexOfEn]
    : filteredHreflang[0]?.href ?? canonical;

const ogAlternates = ROUTE_LOCALES.filter((lc) => lc !== locale && allowedHreflangs.has(lc));

/** GA4 — omit in dev so local previews do not pollute reports. Override via `PUBLIC_GA_MEASUREMENT_ID`. */
const ga4MeasurementId =
  typeof import.meta.env.PUBLIC_GA_MEASUREMENT_ID === 'string' &&
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID.trim().length > 0
    ? import.meta.env.PUBLIC_GA_MEASUREMENT_ID.trim()
    : 'G-ZMRNL5GG8M';
---

<!doctype html>
<html lang={htmlLang} data-site-root={siteDomain}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {noindex ? <meta name="robots" content="noindex, follow" /> : null}
    {import.meta.env.DEV ? (
      <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    ) : null}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {prevUrl ? <link rel="prev" href={prevUrl} /> : null}
    {nextUrl ? <link rel="next" href={nextUrl} /> : null}
    {
      filteredHreflang.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />

    {
      import.meta.env.PROD ? (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`} />
          <script defer is:inline define:vars={{ ga4MeasurementId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', ga4MeasurementId);
          </script>
        </>
      ) : null
    }

    <meta property="og:type" content={ogType} />
    {ogType === 'article' && articlePublishedTime ? (
      <>
        <meta property="article:published_time" content={articlePublishedTime} />
        <meta
          property="article:modified_time"
          content={articleModifiedTime ?? articlePublishedTime}
        />
      </>
    ) : null}
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={OG_LOCALE_BY_ROUTE[locale]} />
    {
      ogAlternates.map((lc) => (
        <meta property="og:locale:alternate" content={OG_LOCALE_BY_ROUTE[lc]} />
      ))
    }
    <meta property="og:image" content={ogImageAbs} />
    {ogImageUsesDefaultDims ? (
      <>
        <meta property="og:image:width" content={String(defaultOgImageWidth)} />
        <meta property="og:image:height" content={String(defaultOgImageHeight)} />
      </>
    ) : null}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageAbs} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href={litbuyCheckoutOrigin} crossorigin />
    <link rel="dns-prefetch" href={litbuyCheckoutOrigin} />
    <link rel="preconnect" href={new URL(litrepstarCatalogRoot).origin} crossorigin />
    <link rel="dns-prefetch" href={new URL(litrepstarCatalogRoot).origin} />
    <link rel="preconnect" href="https://si.geilicdn.com" crossorigin />
    <link rel="dns-prefetch" href="https://si.geilicdn.com" />
    <link
      rel="preload"
      href={interLatinFontUrl}
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      lcpPreloadImages?.map((href) => (
        <link
          rel="preload"
          as="image"
          href={href}
          fetchpriority="high"
          media="(min-width: 641px)"
        />
      ))
    }
    {
      mobileLcpPreloadImages?.map((href) => (
        <link
          rel="preload"
          as="image"
          href={href}
          fetchpriority="high"
          media="(max-width: 640px)"
        />
      ))
    }

    {ld.map((node) => (
      <script type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}

    <style is:global>
      :root {
        /* LitBuy-like neutrals + pink accent */
        --bg: #f6f6fb;
        --surface: #ffffff;
        --text: #1a1a1a;
        --muted: #666666;
        --border: #e8e8f0;
        --accent: #ff1e6f;
        --accent-dark: #e91362;
        --accent-soft: rgba(255, 30, 111, 0.08);
        --accent-badge-bg: #fee7ef;
        --oob-pink: #ff1e6f;
        --hero-surface: #ffffff;
        --hero-surface-2: #f9f9fc;
        --page-max-w: none;
        --page-gutter-x: clamp(16px, 3.5vw, 28px);
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
        margin: 0;
        padding: 0;
        background-color: var(--surface);
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-display: swap;
        font-weight: 100 900;
        src: url('/fonts/inter-latin-ext-wght-normal.woff2') format('woff2-variations');
        unicode-range:
          U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304,
          U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB,
          U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-display: swap;
        font-weight: 100 900;
        src: url('/fonts/inter-latin-wght-normal.woff2') format('woff2-variations');
        unicode-range:
          U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304,
          U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215,
          U+FEFF, U+FFFD;
      }
      body {
        margin: 0;
        padding: 0;
        font-family: Inter, system-ui, sans-serif;
        color: var(--text);
        background: var(--surface);
        line-height: 1.6;
      }
      a {
        color: var(--accent-dark);
      }
      .wrap {
        box-sizing: border-box;
        width: 100%;
        max-width: var(--page-max-w);
        margin-inline: auto;
        padding-left: max(var(--page-gutter-x), env(safe-area-inset-left, 0px));
        padding-right: max(var(--page-gutter-x), env(safe-area-inset-right, 0px));
      }
      /* Desktop: symmetric side gutters so cards stay centered; room for the quick-links dock */
      @media (min-width: 641px) {
        .wrap {
          --page-dock-inline-gutter: 2.5rem;
          padding-left: calc(
            max(var(--page-gutter-x), env(safe-area-inset-left, 0px)) +
              var(--page-dock-inline-gutter)
          );
          padding-right: calc(
            max(var(--page-gutter-x), env(safe-area-inset-right, 0px)) +
              var(--page-dock-inline-gutter)
          );
        }
      }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 40;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--border);
      }
      .nav-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.75rem 0;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        color: var(--text);
        text-decoration: none;
        white-space: nowrap;
      }
      .brand-mark {
        width: 34px;
        height: 34px;
      }
      .nav-bar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem 0 0.75rem;
      }
      .nav-bar-link {
        flex: 0 0 auto;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        padding: 0.35rem 0.6rem;
        border-radius: 999px;
        border: 1px solid transparent;
      }
      .nav-bar-link:hover {
        color: var(--accent-dark);
        border-color: var(--border);
        background: #fff;
      }
      .nav-categories-dd {
        position: relative;
        flex: 0 0 auto;
      }
      .nav-categories-trigger {
        list-style: none;
        cursor: pointer;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--muted);
        padding: 0.35rem 1.85rem 0.35rem 0.65rem;
        border-radius: 999px;
        border: 1px solid transparent;
        position: relative;
        user-select: none;
      }
      .nav-categories-trigger::-webkit-details-marker {
        display: none;
      }
      .nav-categories-trigger::after {
        content: '';
        position: absolute;
        right: 0.55rem;
        top: 50%;
        width: 0.32rem;
        height: 0.32rem;
        border-right: 2px solid var(--muted);
        border-bottom: 2px solid var(--muted);
        transform: translateY(-58%) rotate(45deg);
        opacity: 0.85;
      }
      .nav-categories-dd[open] .nav-categories-trigger::after {
        transform: translateY(-20%) rotate(-135deg);
      }
      .nav-categories-trigger:hover {
        color: var(--accent-dark);
        border-color: var(--border);
        background: #fff;
      }
      .nav-categories-dd[open] .nav-categories-trigger {
        color: var(--accent-dark);
        border-color: var(--border);
        background: #fff;
      }
      .nav-categories-panel {
        position: absolute;
        left: 0;
        top: calc(100% + 0.35rem);
        min-width: 12.5rem;
        max-height: min(70vh, 22rem);
        overflow-y: auto;
        padding: 0.35rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        box-shadow:
          0 10px 25px rgba(15, 23, 42, 0.12),
          0 2px 6px rgba(15, 23, 42, 0.06);
        z-index: 60;
      }
      .nav-categories-link {
        display: block;
        padding: 0.45rem 0.6rem;
        border-radius: 0.35rem;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text);
        text-decoration: none;
      }
      .nav-categories-link:hover {
        background: var(--accent-soft);
        color: var(--accent-dark);
      }
      .page-mast,
      .hero-mast {
        width: min(76rem, 100%);
        margin-inline: auto;
      }
      .hero-mast > .oob-site-header--embedded + .hero-shell {
        margin-top: 0.25rem;
      }
      .hero {
        background:
          radial-gradient(120% 80% at 50% -15%, rgba(255, 30, 111, 0.07), transparent 42%),
          linear-gradient(180deg, var(--hero-surface) 0%, var(--hero-surface-2) 55%, var(--bg) 100%);
        color: var(--text);
        /* 顶栏 Discord 横幅已含 safe-area；hero 不再重复加 padding-top */
        padding: 0 0 4.75rem;
        border-bottom: 1px solid var(--border);
      }
      .hero-shell {
        display: flex;
        justify-content: flex-start;
        width: 100%;
      }
      .hero h1 {
        margin: 0 0 0.85rem;
        font-size: clamp(2.15rem, 5vw, 3.35rem);
        line-height: 1.12;
        letter-spacing: -0.025em;
      }
      .hero p.lead {
        margin: 0 auto 1.65rem;
        max-width: 48rem;
        font-size: 0.95rem;
        line-height: 1.58;
        color: var(--muted);
      }
      .hero p.lead.lead-tagline {
        margin-bottom: 0.4rem;
        font-size: 1.05rem;
        line-height: 1.38;
        color: var(--text);
      }
      .hero .lead-kicker {
        margin: 0 auto 1.05rem;
        max-width: 48rem;
        font-size: 0.82rem;
        line-height: 1.42;
        letter-spacing: 0.025em;
        font-weight: 600;
        color: var(--muted);
      }
      .hero p.lead.lead-body {
        margin-top: 0;
      }
      .hero-copy {
        min-width: 0;
        flex: 1 1 min(26rem, 100%);
        max-width: min(50rem, 100%);
        text-align: center;
      }
      .hero .cta-row {
        justify-content: center;
      }
      .hero .ml-search-bar {
        margin-inline: auto;
        max-width: min(48rem, 100%);
      }
      .hero .ml-search-bar__pill {
        min-height: 3.2rem;
      }
      .hero .ml-search-bar__submit {
        font-size: 0.9rem;
        padding: 0 1.25rem;
      }
      .hero .btn {
        padding: 0.78rem 1.38rem;
        font-size: 1.02rem;
      }
      .hero-layout {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-start;
        column-gap: clamp(0.6rem, 3vw, 1.35rem);
        row-gap: 1.6rem;
        width: 100%;
      }
      .hero-plane-wrap {
        display: flex;
        flex: 0 0 auto;
        justify-content: flex-start;
        align-items: center;
        pointer-events: none;
        user-select: none;
      }
      .hero-plane-img {
        width: auto;
        max-width: min(31rem, 54vw);
        height: auto;
        display: block;
      }
      @media (max-width: 900px) {
        .hero-layout {
          flex-direction: column;
        }
        .hero-copy {
          max-width: 100%;
          flex-basis: auto;
        }
        .hero-plane-wrap {
          justify-content: center;
          align-self: center;
          margin-top: 0.2rem;
        }
        .hero-plane-img {
          max-width: min(21rem, 78vw);
        }
      }
      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        padding: 0.65rem 1.15rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        border: 1px solid transparent;
      }
      .btn-primary {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
      }
      .btn-primary:hover {
        filter: brightness(1.06);
      }
      .btn-ghost {
        background: transparent;
        color: var(--text);
        border-color: var(--border);
      }
      .btn-ghost:hover {
        background: var(--accent-soft);
        border-color: rgba(255, 30, 111, 0.22);
      }
      .band-alt .cta-row .btn-primary {
        background: var(--accent-dark);
        color: #fff;
        border-color: var(--accent-dark);
      }
      .band-alt .cta-row .btn-primary:hover {
        filter: brightness(1.06);
      }
      .band-alt .cta-row .btn-ghost {
        color: var(--text);
        border-color: var(--border);
      }
      .band-alt .cta-row .btn-ghost:hover {
        background: #f4f4f5;
      }
      section {
        padding: 2.75rem 0;
      }
      .band-alt {
        background: var(--surface);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      h2 {
        margin: 0 0 0.5rem;
        font-size: 1.5rem;
      }
      h3 {
        margin: 2rem 0 0.5rem;
        font-size: 1.125rem;
      }
      .section-intro {
        color: var(--muted);
        max-width: 52rem;
        margin: 0 0 1.75rem;
      }
      .home-category-banners-shell {
        --hbc-gap: 0.65rem;
        container-type: inline-size;
        container-name: home-category-banners;
        position: relative;
        width: 100%;
        max-width: 72rem;
        margin: 0 auto 1.35rem;
      }
      .home-category-banners__viewport {
        overflow-x: auto;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        scrollbar-width: thin;
        scrollbar-color: rgba(15, 23, 42, 0.22) transparent;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior-x: contain;
        cursor: grab;
        outline: none;
      }
      .home-category-banners__viewport.is-dragging {
        cursor: grabbing;
        scroll-snap-type: none;
        scroll-behavior: auto;
        user-select: none;
      }
      .home-category-banners__viewport.is-dragging .home-category-banner-img {
        pointer-events: none;
      }
      .home-category-banners__viewport:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      .home-category-banners.home-category-banners__track {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        gap: var(--hbc-gap);
        width: max-content;
        min-width: 100%;
        padding: 2px 0 6px;
        box-sizing: border-box;
      }
      .home-category-banners__slide {
        flex: 0 0 calc((100cqi - 3 * var(--hbc-gap)) / 4);
        min-width: 0;
        scroll-snap-align: start;
      }
      @container home-category-banners (max-width: 900px) {
        .home-category-banners__slide {
          flex-basis: calc((100cqi - var(--hbc-gap)) / 2);
        }
      }
      /* Phones / narrow shells: one full-width card per view (no peek of next slide). */
      @container home-category-banners (max-width: 640px) {
        .home-category-banners__slide {
          flex: 0 0 100cqi;
          scroll-snap-align: start;
          scroll-snap-stop: always;
        }
      }
      .home-category-banners__slide > .home-category-banner-link,
      .home-category-banners__slide > .home-category-banner-tile {
        height: 100%;
      }
      .home-category-banners__btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 2;
        width: 2.5rem;
        height: 2.5rem;
        padding: 0;
        border: none;
        border-radius: 999px;
        display: grid;
        place-items: center;
        background: rgba(255, 255, 255, 0.76);
        color: rgba(51, 65, 85, 0.92);
        box-shadow: 0 2px 14px rgba(15, 23, 42, 0.14);
        cursor: pointer;
        transition:
          opacity 0.15s ease,
          background 0.15s ease,
          box-shadow 0.15s ease;
      }
      .home-category-banners__btn:hover:not(:disabled) {
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 4px 18px rgba(15, 23, 42, 0.18);
      }
      .home-category-banners__btn:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      .home-category-banners__btn:disabled {
        opacity: 0.32;
        cursor: default;
        pointer-events: none;
      }
      .home-category-banners__btn--prev {
        left: 0.35rem;
      }
      .home-category-banners__btn--next {
        right: 0.35rem;
      }
      .home-category-banner-link {
        display: block;
        margin: 0;
        padding: 0;
        border-radius: 0.55rem;
        overflow: hidden;
        border: 1px solid var(--border);
        outline-offset: 3px;
        line-height: 0;
        text-decoration: none;
        transition:
          box-shadow 0.18s ease,
          transform 0.18s ease;
      }
      .home-category-banner-link:hover {
        box-shadow:
          0 10px 28px rgba(15, 23, 42, 0.1),
          0 3px 8px rgba(15, 23, 42, 0.05);
        transform: translateY(-2px);
      }
      .home-category-banner-link:focus-visible {
        outline: 2px solid var(--accent);
      }
      .home-category-banner-tile {
        display: block;
        margin: 0;
        padding: 0;
        border-radius: 0.55rem;
        overflow: hidden;
        border: 1px solid var(--border);
        line-height: 0;
      }
      .home-category-banner-img {
        width: 100%;
        height: auto;
        display: block;
        vertical-align: top;
      }
      .category-explore {
        text-align: center;
      }
      .category-explore-title {
        font-size: clamp(1.35rem, 3vw, 1.85rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 0 0 1.25rem;
      }
      .category-explore-sub {
        margin: 0;
        padding-bottom: 0.25rem;
        font-size: 0.9rem;
        color: var(--muted);
      }
      .category-explore-kicker {
        font-size: 1.05rem;
        font-weight: 700;
        margin: 0 0 0.75rem;
        padding-top: 0.25rem;
        line-height: 1.35;
        color: var(--text);
      }
      .category-explore-intro {
        margin: 0 auto 0.65rem;
        max-width: 40rem;
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--muted);
        text-wrap: balance;
      }
      .category-explore-sub a {
        font-weight: 600;
      }
      .cat-icon-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 0.75rem 0.6rem;
        width: 100%;
        max-width: 58rem;
        margin: 0 auto 1.15rem;
        justify-items: stretch;
        align-items: start;
      }
      @media (max-width: 720px) {
        .cat-icon-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
          max-width: 28rem;
        }
      }
      @media (max-width: 400px) {
        .cat-icon-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }
      .cat-icon-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        gap: 0.5rem;
        width: 100%;
        min-height: 7.5rem;
        padding: 0.7rem 0.45rem 0.65rem;
        border-radius: 0.75rem;
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        text-decoration: none;
        color: var(--text);
        outline-offset: 2px;
        transition:
          transform 0.16s ease,
          border-color 0.16s ease,
          box-shadow 0.16s ease;
      }
      .cat-icon-link:hover {
        transform: translateY(-2px);
        border-color: #dfe3ec;
        box-shadow:
          0 10px 26px rgba(15, 23, 42, 0.07),
          0 2px 6px rgba(15, 23, 42, 0.04);
      }
      .cat-icon-link:focus-visible {
        outline: 2px solid var(--accent);
      }
      .cat-icon-img {
        width: 4.5rem;
        height: 4.5rem;
        object-fit: contain;
        display: block;
        flex-shrink: 0;
        border-radius: 50%;
        /* PNG 透明区在 img 上铺白底，避免透见灰底/网格感 */
        background: #fff;
      }
      @media (min-width: 640px) {
        .cat-icon-img {
          width: 5.25rem;
          height: 5.25rem;
        }
      }
      .cat-icon-label {
        font-size: 0.8125rem;
        font-weight: 600;
        line-height: 1.3;
        text-align: center;
        color: var(--text);
        padding: 0 0.15rem;
      }
      .category-below-icon {
        display: flex;
        justify-content: center;
        margin: 0 auto 1.25rem;
      }
      .category-below-icon-img {
        width: 52px;
        height: 52px;
        display: block;
        flex-shrink: 0;
      }
      .category-below-icon-link {
        display: inline-flex;
        line-height: 0;
        border-radius: 10px;
        outline-offset: 3px;
        transition: opacity 0.15s ease, transform 0.15s ease;
      }
      .category-below-icon-link:hover {
        opacity: 0.92;
        transform: scale(1.04);
      }
      .category-below-icon-link:focus-visible {
        outline: 2px solid var(--accent);
      }
      .guide h3:first-of-type {
        margin-top: 0;
      }
      .guide p {
        margin: 0.5rem 0 0;
        max-width: 52rem;
        color: var(--muted);
      }
      footer {
        padding: 2rem 0 2.75rem;
        background: var(--surface);
        border-top: 1px solid var(--border);
        font-size: 0.875rem;
        color: var(--muted);
      }
      footer strong {
        color: var(--text);
      }
      .simple-page-title {
        margin: 0 0 1rem;
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 800;
        letter-spacing: -0.02em;
      }
    </style>
  </head>
  <body>
    {showDiscordTopBanner ? <DiscordTopBanner /> : null}
    <slot />
    <FloatingDock />
  </body>
</html>
